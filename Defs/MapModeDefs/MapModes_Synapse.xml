<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <MapModeFramework.MapModeDef>
    <defName>SynapsePopulationDensity</defName>
    <label>dwellings</label>
    <description>Visualizes the density of pawn dwellings across the planet.</description>
    <mapModeClass>RimSynapse.RegionsAndTerritories.MapMode_PopulationDensity</mapModeClass>
    <worldLayerClass>MapModeFramework.WorldLayer_MapMode_Terrain</worldLayerClass>
    <iconPath>UI/MapModes/Default</iconPath>
    <canCache>true</canCache>
    <includeWater>false</includeWater>
  </MapModeFramework.MapModeDef>

  <MapModeFramework.MapModeDef>
    <defName>SynapseFactionTerritory</defName>
    <label>faction domains</label>
    <description>Visualizes national domains and zones of control.</description>
    <mapModeClass>RimSynapse.RegionsAndTerritories.MapMode_FactionTerritory</mapModeClass>
    <worldLayerClass>MapModeFramework.WorldLayer_MapMode_Region</worldLayerClass>
    <iconPath>UI/MapModes/Default</iconPath>
    <canCache>true</canCache>
    <includeWater>false</includeWater>
    <RegionProperties>
      <overrideSelector>true</overrideSelector>
      <doBorders>true</doBorders>
      <borderWidth>0.7</borderWidth>
    </RegionProperties>
  </MapModeFramework.MapModeDef>

  <MapModeFramework.MapModeDef>
    <defName>SynapseGeographicProvinces</defName>
    <label>regions</label>
    <description>Visualizes the geographic regions and valleys on the world map.</description>
    <mapModeClass>RimSynapse.RegionsAndTerritories.MapMode_GeographicProvinces</mapModeClass>
    <worldLayerClass>MapModeFramework.WorldLayer_MapMode_Region</worldLayerClass>
    <iconPath>UI/MapModes/Default</iconPath>
    <canCache>true</canCache>
    <includeWater>false</includeWater>
    <drawHills>true</drawHills>
    <RegionProperties>
      <overrideSelector>true</overrideSelector>
      <doBorders>true</doBorders>
      <borderWidth>0.7</borderWidth>
    </RegionProperties>
  </MapModeFramework.MapModeDef>

  <MapModeFramework.MapModeDef>
    <defName>SynapseMapModeGroup</defName>
    <label>RimSynapse Regions and Territories</label>
    <description>Visualizes world analytics from RimSynapse Regions and Territories (dropdown list).</description>
    <mapModeClass>RimSynapse.RegionsAndTerritories.MapMode_SynapseGroup</mapModeClass>
    <worldLayerClass>MapModeFramework.WorldLayer_MapMode</worldLayerClass>
    <iconPath>UI/MapModes/SynapseGroup</iconPath>
    <canCache>false</canCache>
    <includeWater>false</includeWater>
  </MapModeFramework.MapModeDef>
</Defs>
